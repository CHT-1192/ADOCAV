	cd /d C:\Users\XUEMIN~1\Projects\ADOCAV\b && $(MAKE) $(MAKESILENT) -f _deps\miniaudio-build\CMakeFiles\miniaudio.dir\build.make _deps/miniaudio-build/CMakeFiles/miniaudio.dir/miniaudio.c.obj
.PHONY : miniaudio.c.obj

miniaudio.i: miniaudio.c.i
.PHONY : miniaudio.i

# target to preprocess a source file
miniaudio.c.i:
